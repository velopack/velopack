<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net472;net8.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>13</LangVersion>
    <SignAssembly>false</SignAssembly>
    <NoWarn>$(NoWarn);NU5128</NoWarn>
    <GenerateNuspecDependsOn>$(GenerateNuspecDependsOn);PublishVpkForPackage</GenerateNuspecDependsOn>
    <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);IncludeTfmDependenciesInPackage;IncludeVpkInPackage</TargetsForTfmSpecificContentInPackage>
  </PropertyGroup>

  <PropertyGroup>
    <VelopackPackageId>Velopack.Build</VelopackPackageId>
    <VelopackPackageVendorLibs>true</VelopackPackageVendorLibs>
    <PackRustAssets>false</PackRustAssets>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <!-- TODO: we might be able to remove the entire SelfContained.targets file now -->
    <VelopackPackageSelfContained>false</VelopackPackageSelfContained>
    <_VelopackVpkPackLocation>tools\net8.0\any\</_VelopackVpkPackLocation>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\..\lib-csharp\Util\ProcessExtensions.Shared.cs" Link="ProcessExtensions.Shared.cs" />
    <Compile Include="..\Velopack.Packaging\Compression\DeltaMode.cs" Link="DeltaMode.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Build.Utilities.Core" Version="17.14.28" />
    <PackageReference Include="Microsoft.IO.Redist" Version="6.1.3" Condition="'$(TargetFramework)' == 'net472'" />
    <PackageReference Include="Riok.Mapperly" Version="4.3.1" />
    <PackageReference Include="Microsoft.Build.Utilities.Core" Version="17.14.28" PrivateAssets="All" />
    <PackageReference Include="Microsoft.IO.Redist" Version="6.1.3" Condition="'$(TargetFramework)' == 'net472'" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <ProjectReference Include="..\Velopack.Vpk\Velopack.Vpk.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <PrivateAssets>all</PrivateAssets>
    </ProjectReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\lib-csharp\Velopack.csproj">
      <PrivateAssets>none</PrivateAssets>
    </ProjectReference>
  </ItemGroup>

  <ItemGroup>
    <None Include="Velopack.Build.targets" Pack="true" PackagePath="build/Velopack.Build.targets" />
    <None Include="Velopack.Build.props" Pack="true" PackagePath="build/Velopack.Build.props" />
  </ItemGroup>


  <ItemGroup>
    <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
      <_Parameter1>VelopackVpkPackLocation</_Parameter1>
      <_Parameter2>$(_VelopackVpkPackLocation)</_Parameter2>
    </AssemblyAttribute>
  </ItemGroup>

  <!-- Publish Velopack.Vpk and include output in the tools directory -->
  <Target Name="PublishVpkForPackage" BeforeTargets="IncludeVpkInPackage" Condition="'$(TargetFramework)' == 'net8.0'">
    <MSBuild Projects="$(MSBuildThisFileDirectory)..\Velopack.Vpk\Velopack.Vpk.csproj"
             Targets="Publish"
             Properties="Configuration=$(Configuration);TargetFramework=net8.0;PublishDir=$(MSBuildThisFileDirectory)..\..\..\build\$(Configuration)\net8.0\publish\" />
  </Target>

  <Target Name="IncludeVpkInPackage" Condition="'$(TargetFramework)' == 'net8.0'">
    <ItemGroup>
      <_VpkPublishFiles Include="$(MSBuildThisFileDirectory)..\..\..\build\$(Configuration)\net8.0\publish\**\*.*" />
      <TfmSpecificPackageFile Include="@(_VpkPublishFiles)">
        <PackagePath>$(_VelopackVpkPackLocation)%(RecursiveDir)</PackagePath>
      </TfmSpecificPackageFile>
    </ItemGroup>
  </Target>

  <Target Name="IncludeTfmDependenciesInPackage">
    <ItemGroup>
      <!-- Exclude the publish folder and vpk files as vpk is packaged separately in tools folder -->
      <TfmSpecificPackageFile Include="$(TargetDir)*.*" Exclude="$(TargetDir)vpk.*;$(TargetDir)Velopack.Core.*;$(TargetDir)Velopack.Packaging.*;$(TargetDir)Velopack.Deployment.*;$(TargetDir)Velopack.Flow.*;$(TargetDir)Velopack.IcoLib.*;$(TargetDir)Velopack.Packaging.Unix.*;$(TargetDir)Velopack.Packaging.Windows.*">
        <PackagePath>build\$(TargetFramework)</PackagePath>
      </TfmSpecificPackageFile>
      <TfmSpecificPackageFile Include="$(TargetDir)runtimes\**\*.*">
        <PackagePath>build\$(TargetFramework)\runtimes</PackagePath>
      </TfmSpecificPackageFile>
    </ItemGroup>
  </Target>

</Project>