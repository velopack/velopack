<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>14</LangVersion>
    <SignAssembly>false</SignAssembly>
    <NoWarn>$(NoWarn);NU5128</NoWarn>
    <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);IncludeTfmDependenciesInPackage</TargetsForTfmSpecificContentInPackage>
  </PropertyGroup>

  <PropertyGroup>
    <VelopackPackageId>Velopack.Build</VelopackPackageId>
    <VelopackPackageVendorLibs>true</VelopackPackageVendorLibs>
    <PackRustAssets>false</PackRustAssets>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <VelopackPackageSelfContained>false</VelopackPackageSelfContained>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\..\lib-csharp\Util\ProcessExtensions.Shared.cs" Link="ProcessExtensions.Shared.cs" />
    <Compile
      Include="..\Velopack.Packaging\InstallLocation.cs" Link="InstallLocation.cs" />
    <Compile
      Include="..\Velopack.Packaging\Compression\DeltaMode.cs" Link="DeltaMode.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Build.Utilities.Core" Version="17.14.28" />
    <PackageReference Include="Riok.Mapperly" Version="4.3.1" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <None Include="Velopack.Build.targets" Pack="true" PackagePath="build/Velopack.Build.targets" />
    <None Include="Velopack.Build.props" Pack="true" PackagePath="build/Velopack.Build.props" />
  </ItemGroup>


  <Target Name="SetVelopackNuGetVersion" AfterTargets="GetBuildVersion">
    <ItemGroup>
      <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
        <_Parameter1>VelopackNugetVersion</_Parameter1>
        <_Parameter2>$(NuGetPackageVersion)</_Parameter2>
      </AssemblyAttribute>
    </ItemGroup>
  </Target>

  <Target Name="IncludeTfmDependenciesInPackage">
    <ItemGroup>
      <!-- Exclude the publish folder, runtimes, and vpk files as vpk is packaged separately in tools folder -->
      <TfmSpecificPackageFile Include="$(TargetDir)*.*">
        <PackagePath>build\$(TargetFramework)</PackagePath>
      </TfmSpecificPackageFile>
    </ItemGroup>
  </Target>

</Project>