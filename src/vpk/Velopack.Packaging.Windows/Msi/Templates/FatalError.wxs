<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
    <Fragment>
        <UI>
            <Dialog Id="FatalError" Width="370" Height="270" Title="[MsiDlgTitle]">
                <Control Id="Finish" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Cancel="yes" Text="[MsiBtnFinish]">
                    <Publish Event="EndDialog" Value="Exit" />
                </Control>
                <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Disabled="yes" Text="[MsiBtnCancel]" />
                <Control Id="Bitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="234" TabSkip="no" Text="WixUI_Bmp_Dialog" />
                <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Disabled="yes" Text="[MsiBtnBack]" />
                <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
                <Control Id="Title" Type="Text" X="135" Y="20" Width="220" Height="60" Transparent="yes" NoPrefix="yes" Text="[MsiFatalTitle]" />
                <Control Id="Description" Type="Text" X="135" Y="70" Width="220" Height="80" Transparent="yes" NoPrefix="yes" Text="[MsiFatalDescription1] [MsiFatalDescription2]" />
            </Dialog>

            <InstallUISequence>
                <Show Dialog="virtual FatalError" OnExit="error" />
            </InstallUISequence>

            <AdminUISequence>
                <Show Dialog="virtual FatalError" OnExit="error" />
            </AdminUISequence>
        </UI>
    </Fragment>
</Wix>
